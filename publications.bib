
@book{miszuda_evolutionary_2018,
	address = {eprint: arXiv:1812.01337},
	title = {Evolutionary stage of the massive component of the double-lined eclipsing binary {V380} {Cygni}},
	url = {https://ui.adsabs.harvard.edu/abs/2018phos.confE..33M},
	abstract = {We determine the age of the eclipsing binary V380 Cygni, whose components have a significant mass ratio, M\_B/M\_A≈0.6. Because this binary exhibits spectral lines of both components, the values of masses and radii could be determined with a very high accuracy. Assuming that both components are on the main sequence, we derive the age of about 16 Myr. However, in this case the primary needs a large overshooting from the convective core (fov ≈ 0.04) and higher metallicity (Z ≈ 0.02). It is difficult to tell whether such a high value of overshooting from the convective core is reliable or rather mimics other mixing processes, which took place on the whole main sequence evolution, e.g., resulting from diffusion, rotation etc. If the primary is already in the overall contraction phase or just after, then the age of the system is about 13 Myr. Based on the available observations, we cannot resolve what is the evolutionary stage of the V380 Cyg system. The analysis of the Kepler light curve does not show any significant periodicity besides the orbital frequency and, most probably, the rotational frequency and their multiplets.},
	urldate = {2024-12-05},
	author = {Miszuda, A. and Daszyńska-Daszkiewicz, J. and Szewczuk, W.},
	month = sep,
	year = {2018},
	note = {ADS Bibcode: 2018phos.confE..33M},
	keywords = {stars: early‑type, stars: evolution, binaries: eclipsing, binaries: spectroscopic, Zenodo community phost, Astrophysics - Solar and Stellar Astrophysics},
}

@book{miszuda_beta-cep_2020,
	title = {{\textbackslash}beta-{Cep} pulsator in the eclipsing binary {V381} {Car}: mode identification and seismic modelling},
	shorttitle = {{\textbackslash}beta-{Cep} pulsator in the eclipsing binary {V381} {Car}},
	url = {https://ui.adsabs.harvard.edu/abs/2020svos.conf..345M},
	abstract = {We re-determine the binary orbit of the single-line eclipsing binary V381 Car. After subtracting the fitted eclipse light-curve, we performed a Fourier analysis in each Strömgren passband. We found 5 independent frequencies, and made mode identifications from the photometric observables and from the spectroscopic IPS diagrams. We identified three frequencies; \${\textbackslash}nu\_1\$ and \${\textbackslash}nu\_2\$ are prograde quadrupole modes, and \${\textbackslash}nu\_4\$ is a dipole zonal mode. Another two frequencies were most probably higher-degree modes. We constructed preliminary seismic models to fit the dominant frequency and to investigate instability of the whole frequency range observed.},
	urldate = {2024-12-05},
	author = {Miszuda, A. and Daszyńska-Daszkiewicz, J. and Szewczuk, W.},
	month = jan,
	year = {2020},
	note = {ADS Bibcode: 2020svos.conf..345M},
	keywords = {stars: early-type, oscillations, binaries: eclipsing},
}

@book{miszuda_kic_2020,
	title = {{KIC} 10661783 - binary system with a {\textbackslash}delta {Sct} type component},
	url = {https://ui.adsabs.harvard.edu/abs/2020svos.conf..349M},
	abstract = {We present the analysis of KIC 10661783, an eclipsing binary system with a \${\textbackslash}delta\$ Scuti component. We use all available Kepler data from both short and long cadences to model the binary system and to subtract the calculated theoretical eclipsing light curve from the original data. The Fourier analysis of the light curve corrected for the binarity effects shows a rich oscillation spectrum with most prominent peaks concentrated in the range of 20 - 30{\textbackslash}cpd. We find small-amplitude signals in the low-frequency range that can be a manifestation of high-radial order g-mode pulsations.},
	urldate = {2024-12-05},
	author = {Miszuda, A. and Szewczuk, W. and Daszyńska-Daszkiewicz, J.},
	month = jan,
	year = {2020},
	note = {ADS Bibcode: 2020svos.conf..349M},
	keywords = {stars: binaries: eclipsing, stars: binaries: spectroscopic, stars: low-mass, stars: oscillations},
}

@book{miszuda_binary_2020,
	address = {eprint: arXiv:2001.11873},
	title = {Binary and seismic modelling of the {Kepler} system {KIC} 10661783 with the {\textbackslash}delta {Scuti} component},
	volume = {10},
	url = {https://ui.adsabs.harvard.edu/abs/2020past.conf..371M},
	abstract = {We present the results of the comprehensive study of the eclipsing binary system KIC 10661783 whose main component is a \${\textbackslash}delta\$ Scuti pulsating star. The Fourier analysis of the whole Kepler light curve, corrected for the binary effects, reveals 750 frequency peaks. Those with the highest amplitudes concentrate in the range of \$20 - 30\${\textbackslash}cpd. The small-amplitude signals, found in the low-frequency range, can be a manifestation of gravity-mode pulsations. To reproduce the observed range of frequencies, we computed a grid of pulsational models. To obtain instability for high-order g modes, an increase of the mean opacity at the depth corresponding to the temperature of about 115,000 K was indispensable. For evolutionary computations the MESA-binary module was used to include interactions between the binary components.},
	urldate = {2024-12-05},
	author = {Miszuda, Amadeusz and Szewczuk, Wojciech and Daszyńska-Daszkiewicz, Jadwiga},
	month = oct,
	year = {2020},
	note = {ADS Bibcode: 2020past.conf..371M},
	keywords = {Astrophysics - Solar and Stellar Astrophysics},
}

@article{miszuda_eclipsing_2021,
	title = {The eclipsing binary systems with δ {Scuti} component - {I}. {KIC} 10661783},
	volume = {505},
	issn = {0035-8711},
	url = {https://ui.adsabs.harvard.edu/abs/2021MNRAS.505.3206M},
	doi = {10.1093/mnras/stab1597},
	abstract = {We present a comprehensive study of the eclipsing binary system KIC 10661783. The analysis of the whole Kepler light curve, corrected for the binary effects, reveals a rich oscillation spectrum with 590 significant frequency peaks, 207 of which are independent. In addition to typical δ Scuti (δ Sct) frequencies, we find small-amplitude signals in the low-frequency range that, most probably, are a manifestation of gravity-mode pulsations. We perform binary-evolution computations for this system in order to find an acceptable model describing its current stage. Our models show that the binary KIC 10661783 was formed by a rapid, almost conservative, mass transfer that heavily affected the evolution of both components in the past. One of the most important effects of binary evolution is the enormous enrichment of the outer layers of the main component with helium. This fact profoundly influences the pulsational properties of δ Sct star models. For the first time, we demonstrate the effect of binary evolution on pulsational instability. We construct pulsational models of the main component in order to account for the mode instability of the observed frequencies. Whereas the single-star evolution model is pulsational stable in the whole frequency range, its binary-evolution counterpart has unstable modes in both high- and low-frequency ranges. However, to obtain instability in almost a whole range of the observed frequencies, the modification of the mean opacity at the depth corresponding to temperatures log T = 4.69 K and log T = 5.06 K was necessary.},
	urldate = {2024-12-05},
	journal = {Monthly Notices of the Royal Astronomical Society},
	author = {Miszuda, A. and Szewczuk, W. and Daszyńska-Daszkiewicz, J.},
	month = aug,
	year = {2021},
	note = {ADS Bibcode: 2021MNRAS.505.3206M},
	keywords = {binaries: eclipsing, binaries: spectroscopic, stars: low-mass, stars: evolution, stars: oscillations, Astrophysics - Solar and Stellar Astrophysics},
	pages = {3206--3218},
}

@article{miszuda_eclipsing_2022,
	title = {The eclipsing binary systems with δ {Scuti} component - {II}. {AB} {Cas}},
	volume = {514},
	issn = {0035-8711},
	url = {https://ui.adsabs.harvard.edu/abs/2022MNRAS.514..622M},
	doi = {10.1093/mnras/stac1197},
	abstract = {We present a complex study of the eclipsing binary system, AB Cas. The analysis of the whole TESS light curve, corrected for the binary effects, reveals 112 significant frequency peaks with 17 independent signals. The dominant frequency f1 = 17.1564 d-1 is a radial fundamental mode. The O - C analysis of the times of light minima from over 92 yr leads to a conclusion that due to the ongoing mass transfer the system exhibits a change of the orbital period at a rate of 0.03 s per year. In order to find evolutionary models describing the current stage of AB Cas, we perform binary evolution computations. Our results show the AB Cas system as a product of the rapid non-conservative mass transfer with about 5-26 per cent of transferred mass lost from the system. This process heavily affected the orbital characteristics of this binary and its components in the past. In fact, this system closely resemble the formation scenarios of EL CVn type binaries. For the first time, we demonstrate the effect of binary evolution on radial pulsations and determine the lines of constant frequency on the HR diagram. From the binary and seismic modelling, we obtain constraints on various parameters. In particular, we constrain the overshooting parameter, fov ∈ [0.010, 0.018], the mixing-length parameter, αMLT ∈ [1.2, 1.5] and the age, t ∈ [2.3, 3.4] Gyr.},
	urldate = {2024-12-05},
	journal = {Monthly Notices of the Royal Astronomical Society},
	author = {Miszuda, A. and Kołaczek-Szymański, P. A. and Szewczuk, W. and Daszyńska-Daszkiewicz, J.},
	month = jul,
	year = {2022},
	note = {ADS Bibcode: 2022MNRAS.514..622M},
	keywords = {binaries: eclipsing, binaries: spectroscopic, stars: low-mass, stars: oscillations, stars: variables: Scuti, stars: individual: AB Cas, Astrophysics - Solar and Stellar Astrophysics},
	pages = {622--639},
}

@book{miszuda_evolutionary_2022,
	title = {Evolutionary and {Seismic} {Modeling} of the δ {Sct} {Pulsator} in a {Binary} {System} {AB} {Cassiopeia}},
	volume = {12},
	url = {https://ui.adsabs.harvard.edu/abs/2022pas..conf..169M},
	abstract = {We present the analysis of the eclipsing binary system AB Cas, that consists of a δ Sct star and a low-mass companion. The Fourier transform of the TESS light curve, corrected for the orbital model, reveals 114 frequency peaks. The most prominent peak corresponds to the radial fundamental mode. We conduct simultaneous binary evolution and seismic modelling by fitting the masses, the radii, the orbital period of the system, and the dominant pulsational frequency in order to constrain the age and some free parameters of theory.},
	urldate = {2024-12-05},
	author = {Miszuda, Amadeusz and Kołaczek-Szymański, Piotr A. and Szewczuk, Wojciech and Daszyńska-Daszkiewicz, Jadwiga},
	month = oct,
	year = {2022},
	note = {ADS Bibcode: 2022pas..conf..169M},
}

@book{miszuda_pulsational_2024,
	title = {Pulsational characteristics of mass accreting stars in close binary systems},
	url = {https://ui.adsabs.harvard.edu/abs/2024eas..conf.1932M},
	abstract = {Binary systems, especially those that undergo eclipses, are well-proven benchmarks in testing stellar evolution theory. Precise stellar parameters that come from eclipsing binaries analysis aid systems' age determination along with tracing back their evolution history and settling the initial conditions that led the systems to their current form. Eclipsing binaries that contain pulsating components are a special subclass of binaries as they combine information coming from orbital and pulsational analyses. In recent years that subclass led to defining a newly formed branch of tidal asterosiesmology. Whereas the single-star pulsators are rather well understood, the precise effect that binarity and possible mass transfer introduce in the pulsational characteristics of components, especially those that gain mass during their evolution, is yet to be determined and systematised. In my talk, I will highlight some of the most important results from my studies of delta Scuti and beta Cephei pulsators in binary systems. In particular, I will discuss the systematic effects of mass accretion on the pulsational characteristics of stars, such as the evolution of radial mode frequencies during the main sequence evolutionary phase. Also, I will go into the effects that accumulation of helium in outer layers of accretor caused by mass transfer has on excitation of the high radial-order g modes in models of delta Scuti stars.},
	urldate = {2024-12-05},
	author = {Miszuda, Amadeusz},
	month = jul,
	year = {2024},
	note = {ADS Bibcode: 2024eas..conf.1932M},
}

@book{miszuda_ambiguous_2024,
	title = {The ambiguous case of the {V1216} {Sco} eclipsing binary},
	url = {https://ui.adsabs.harvard.edu/abs/2024tkas.confE..84M},
	abstract = {V1216 Scorpii is a newly discovered SB2 eclipsing binary containing a Beta Cephei pulsator (Eze \& Handler 2024). A first inspection of the light curve suggests a borderline between detached and semi-detached geometry and shows the O'Connell effect, high-amplitude pulsations, and a considerable asymmetry of the flux at ingress and egress of the primary eclipse. All these pose challenges to modelling the light curve of this system. Our analysis suggests that V1216 Sco is a post-mass-transfer binary, with 11.7 M⊙ and 4.3 M⊙ main-sequence stars. In our poster, we show the current state of the analysis of the system with the frequency search and the binary evolution modelling.},
	urldate = {2024-12-05},
	author = {Miszuda, Amadeusz and Eze, Christian Ikechukwu and Kahraman Aliçavuş, Filiz and Johnston, Cole and Handler, Gerald},
	month = sep,
	year = {2024},
	note = {ADS Bibcode: 2024tkas.confE..84M},
	keywords = {Zenodo community tasc8-kasc15},
}
