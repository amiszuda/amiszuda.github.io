@book{miszuda_ambiguous_2024,
 abstract = {V1216 Scorpii is a newly discovered SB2 eclipsing binary containing a Beta Cephei pulsator (Eze & Handler 2024). A first inspection of the light curve suggests a borderline between detached and semi-detached geometry and shows the O'Connell effect, high-amplitude pulsations, and a considerable asymmetry of the flux at ingress and egress of the primary eclipse. All these pose challenges to modelling the light curve of this system. Our analysis suggests that V1216 Sco is a post-mass-transfer binary, with 11.7 M⊙ and 4.3 M⊙ main-sequence stars. In our poster, we show the current state of the analysis of the system with the frequency search and the binary evolution modelling.},
 author = {Miszuda, Amadeusz and Eze, Christian Ikechukwu and Kahraman Aliçavuş, Filiz and Johnston, Cole and Handler, Gerald},
 keywords = {Zenodo community tasc8-kasc15},
 month = {September},
 note = {ADS Bibcode: 2024tkas.confE..84M},
 title = {The ambiguous case of the V1216 Sco eclipsing binary},
 url = {https://ui.adsabs.harvard.edu/abs/2024tkas.confE..84M},
 urldate = {2024-12-05},
 year = {2024}
}
