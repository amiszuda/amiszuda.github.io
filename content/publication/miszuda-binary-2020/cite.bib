@book{miszuda_binary_2020,
 abstract = {We present the results of the comprehensive study of the eclipsing binary system KIC 10661783 whose main component is a \$\delta\$ Scuti pulsating star. The Fourier analysis of the whole Kepler light curve, corrected for the binary effects, reveals 750 frequency peaks. Those with the highest amplitudes concentrate in the range of \$20 - 30\$p̧d. The small-amplitude signals, found in the low-frequency range, can be a manifestation of gravity-mode pulsations. To reproduce the observed range of frequencies, we computed a grid of pulsational models. To obtain instability for high-order g modes, an increase of the mean opacity at the depth corresponding to the temperature of about 115,000 K was indispensable. For evolutionary computations the MESA-binary module was used to include interactions between the binary components.},
 address = {eprint: arXiv:2001.11873},
 author = {Miszuda, Amadeusz and Szewczuk, Wojciech and Daszyńska-Daszkiewicz, Jadwiga},
 keywords = {Astrophysics - Solar and Stellar Astrophysics},
 month = {October},
 note = {ADS Bibcode: 2020past.conf..371M},
 title = {Binary and seismic modelling of the Kepler system KIC 10661783 with the \delta Scuti component},
 url = {https://ui.adsabs.harvard.edu/abs/2020past.conf..371M},
 urldate = {2024-12-05},
 volume = {10},
 year = {2020}
}
