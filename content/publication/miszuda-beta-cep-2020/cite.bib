@book{miszuda_beta-cep_2020,
 abstract = {We re-determine the binary orbit of the single-line eclipsing binary V381 Car. After subtracting the fitted eclipse light-curve, we performed a Fourier analysis in each Strömgren passband. We found 5 independent frequencies, and made mode identifications from the photometric observables and from the spectroscopic IPS diagrams. We identified three frequencies; \$\nu_1\$ and \$\nu_2\$ are prograde quadrupole modes, and \$\nu_4\$ is a dipole zonal mode. Another two frequencies were most probably higher-degree modes. We constructed preliminary seismic models to fit the dominant frequency and to investigate instability of the whole frequency range observed.},
 author = {Miszuda, A. and Daszyńska-Daszkiewicz, J. and Szewczuk, W.},
 keywords = {stars: early-type, oscillations, binaries: eclipsing},
 month = {January},
 note = {ADS Bibcode: 2020svos.conf..345M},
 shorttitle = {\beta-Cep pulsator in the eclipsing binary V381 Car},
 title = {\beta-Cep pulsator in the eclipsing binary V381 Car: mode identification and seismic modelling},
 url = {https://ui.adsabs.harvard.edu/abs/2020svos.conf..345M},
 urldate = {2024-12-05},
 year = {2020}
}
