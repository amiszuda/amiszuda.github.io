@book{miszuda_evolutionary_2022,
 abstract = {We present the analysis of the eclipsing binary system AB Cas, that consists of a δ Sct star and a low-mass companion. The Fourier transform of the TESS light curve, corrected for the orbital model, reveals 114 frequency peaks. The most prominent peak corresponds to the radial fundamental mode. We conduct simultaneous binary evolution and seismic modelling by fitting the masses, the radii, the orbital period of the system, and the dominant pulsational frequency in order to constrain the age and some free parameters of theory.},
 author = {Miszuda, Amadeusz and Kołaczek-Szymański, Piotr A. and Szewczuk, Wojciech and Daszyńska-Daszkiewicz, Jadwiga},
 month = {October},
 note = {ADS Bibcode: 2022pas..conf..169M},
 title = {Evolutionary and Seismic Modeling of the δ Sct Pulsator in a Binary System AB Cassiopeia},
 url = {https://ui.adsabs.harvard.edu/abs/2022pas..conf..169M},
 urldate = {2024-12-05},
 volume = {12},
 year = {2022}
}
